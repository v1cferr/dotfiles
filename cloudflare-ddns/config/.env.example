# Cloudflare DDNS — modelo de configuração
# Copie para config/.env e preencha. O config/.env é gitignored:
# NUNCA versione o token real.

# Token da API do Cloudflare (https://dash.cloudflare.com/profile/api-tokens)
# Crie um token com permissão DNS:Edit
API_TOKEN=""

# Zone ID (página de overview do domínio no Cloudflare)
ZONE_ID=""

# Record ID do registro A que será atualizado.
# Descubra com:
#   curl -X GET "https://api.cloudflare.com/client/v4/zones/ZONE_ID/dns_records" \
#     -H "Authorization: Bearer API_TOKEN" | jq
RECORD_ID=""

# Nome do registro DNS (domínio/subdomínio)
RECORD_NAME="ssh.exemplo.com"
