# Override do .desktop do pacote claude-desktop-appimage (AUR).
# Único objetivo: forçar o backend de segredos do Electron pra gnome-libsecret
# (gnome-keyring) em vez do kwallet6 que o launcher do AppImage injeta hardcoded.
# Um arquivo de usuário em ~/.local/share/applications sombreia o de
# /usr/share/applications pelo mesmo nome e sobrevive a updates do pacote.
# Versionado via stow (pacote: claude).
[Desktop Entry]
Type=Application
Name=Claude Desktop
Comment=Claude Desktop Application
Exec=/usr/bin/claude-desktop --password-store=gnome-libsecret %U
Icon=claude-desktop
Terminal=false
Categories=Network;Utility;
MimeType=x-scheme-handler/claude;
StartupWMClass=claude-desktop
StartupNotify=true
Keywords=claude;ai;chat;anthropic;
