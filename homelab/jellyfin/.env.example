# Stack de mídia (Jellyfin + *arr + qBittorrent + cloudflared)
# Copie para .env e preencha. O .env é gitignored — NUNCA versione os tokens.

PUID=1000
PGID=1000
TZ=America/Sao_Paulo

# API keys geradas dentro de cada app (Settings > API Keys)
JELLYFIN_API_KEY=
SONARR_API_KEY=
RADARR_API_KEY=

# Token do túnel Cloudflare (cloudflared) — painel Zero Trust > Tunnels
TUNNEL_TOKEN=
