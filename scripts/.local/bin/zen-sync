#!/usr/bin/env bash

set -euo pipefail

SCRIPT_SOURCE="$(readlink -f "$0")"
DOTFILES_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")/../../.." && pwd)"
ZEN_THEME_DIR="$DOTFILES_DIR/zen-browser"

find_zen_root() {
    local candidates=(
        "$HOME/.zen"
        "$HOME/.var/app/app.zen_browser.zen/.zen"
    )
    local candidate

    for candidate in "${candidates[@]}"; do
        if [[ -f "$candidate/profiles.ini" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    return 1
}

get_default_profile() {
    local profiles_ini="$1"
    local install_default
    local fallback_default

    install_default="$(awk -F= '
        /^\[Install/ { in_install=1; next }
        /^\[/ { if ($0 !~ /^\[Install/) in_install=0 }
        in_install && $1 == "Default" { print $2; exit }
    ' "$profiles_ini")"

    if [[ -n "$install_default" ]]; then
        printf '%s\n' "$install_default"
        return 0
    fi

    fallback_default="$(awk -F= '
        /^\[Profile/ { section=1; path=""; default_flag=0; next }
        /^\[/ && $0 !~ /^\[Profile/ {
            if (section && default_flag == 1 && path != "") {
                print path
                exit
            }
            section=0
        }
        section && $1 == "Path" { path=$2 }
        section && $1 == "Default" { default_flag=$2 }
        END {
            if (section && default_flag == 1 && path != "") {
                print path
            }
        }
    ' "$profiles_ini")"

    if [[ -n "$fallback_default" ]]; then
        printf '%s\n' "$fallback_default"
        return 0
    fi

    return 1
}

backup_if_needed() {
    local target="$1"
    local source="$2"
    local backup

    if [[ -L "$target" ]] && [[ "$(readlink -f "$target")" == "$source" ]]; then
        return 0
    fi

    if [[ -e "$target" || -L "$target" ]]; then
        backup="$target.bak.$(date +%Y%m%d%H%M%S)"
        mv "$target" "$backup"
        printf 'Backup criado: %s\n' "$backup"
    fi
}

link_theme_file() {
    local source="$1"
    local target="$2"

    mkdir -p "$(dirname "$target")"
    backup_if_needed "$target" "$source"
    ln -sfn "$source" "$target"
    printf 'Linked: %s -> %s\n' "$target" "$source"
}

print_status() {
    local zen_root="$1"
    local profile_rel="$2"
    local profile_dir="$zen_root/$profile_rel"
    local chrome_target="$profile_dir/chrome/userChrome.css"
    local prefs_target="$profile_dir/user.js"

    printf 'Zen root: %s\n' "$zen_root"
    printf 'Default profile: %s\n' "$profile_rel"

    if [[ -L "$chrome_target" ]]; then
        printf 'userChrome.css: %s\n' "$(readlink -f "$chrome_target")"
    elif [[ -e "$chrome_target" ]]; then
        printf 'userChrome.css: presente, mas nao linkado\n'
    else
        printf 'userChrome.css: ausente\n'
    fi

    if [[ -L "$prefs_target" ]]; then
        printf 'user.js: %s\n' "$(readlink -f "$prefs_target")"
    elif [[ -e "$prefs_target" ]]; then
        printf 'user.js: presente, mas nao linkado\n'
    else
        printf 'user.js: ausente\n'
    fi
}

main() {
    local zen_root
    local profile_rel
    local profile_dir
    local theme_source
    local prefs_source

    if ! zen_root="$(find_zen_root)"; then
        echo "Zen Browser nao encontrado em ~/.zen nem no caminho Flatpak." >&2
        exit 1
    fi

    if ! profile_rel="$(get_default_profile "$zen_root/profiles.ini")"; then
        echo "Nao foi possivel detectar o perfil padrao do Zen Browser." >&2
        exit 1
    fi

    profile_dir="$zen_root/$profile_rel"
    theme_source="$ZEN_THEME_DIR/userChrome.css"
    prefs_source="$ZEN_THEME_DIR/user.js"

    case "${1:-sync}" in
        --check|check)
            print_status "$zen_root" "$profile_rel"
            ;;
        sync|--sync|"")
            link_theme_file "$theme_source" "$profile_dir/chrome/userChrome.css"
            link_theme_file "$prefs_source" "$profile_dir/user.js"
            print_status "$zen_root" "$profile_rel"
            ;;
        *)
            echo "Uso: $(basename "$0") [sync|check]" >&2
            exit 1
            ;;
    esac
}

main "$@"