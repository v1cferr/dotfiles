# Variáveis de ambiente dos serviços de sistema (Caddy + Cloudflare DDNS).
# Copie este arquivo para `.env` (que é gitignored) e preencha os valores.
# O `.env` é carregado pelo serviço do Caddy via drop-in do systemd:
#   caddy/etc/systemd/system/caddy.service.d/env.conf
#   -> EnvironmentFile=-/home/v1cferr/dotfiles/.env
#
# Depois de preencher, aplique com: sudo ~/dotfiles/scripts/caddy/deploy.sh

# E-mail para avisos/registro da Let's Encrypt.
CADDY_EMAIL=voce@exemplo.com

# Token da API da Cloudflare para o desafio DNS-01 (cert curinga).
# Permissões necessárias: Zone:Read + DNS:Edit na zona do seu domínio.
CLOUDFLARE_API_TOKEN=

# Hash bcrypt do basic_auth do dashboard (dash.v1cferr.dev), usado no acesso
# externo. Gere com:  caddy hash-password --plaintext 'suaSenhaForte'
# Use aspas simples (preservam os '$' do bcrypt no source do bash e no systemd).
CADDY_DASH_HASH=''

# --- Cloudflare DDNS (ssh.v1cferr.dev) ---
# Atualizador de DNS dinâmico (cloudflare-ddns/), que lê este .env centralizado.
# Token PRÓPRIO, diferente do CLOUDFLARE_API_TOKEN do Caddy.
API_TOKEN=
ZONE_ID=
RECORD_ID=
RECORD_NAME=ssh.exemplo.com
