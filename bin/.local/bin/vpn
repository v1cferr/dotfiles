#!/usr/bin/env bash

set -u

DOTFILES_ROOT="${DOTFILES_ROOT:-$HOME/dotfiles}"
UFSCAR_PROFILE="${UFSCAR_PROFILE:-VPN_UFSCar_SCL}"
FAI_PROFILE="${FAI_PROFILE:-FAI.UFSCAR}"
TERMINAL_APP="${TERMINAL:-kitty}"

notify() {
  local msg="$1"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "VPN" "$msg"
  else
    printf '%s\n' "$msg"
  fi
}

# Atualiza o modulo custom/vpn na hora (config.jsonc usa "signal": 8).
refresh_waybar() {
  pkill -RTMIN+8 -x waybar 2>/dev/null || true
}

json_escape() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

choose_launcher() {
  if command -v rofi >/dev/null 2>&1; then
    printf 'rofi\n'
    return
  fi

  if command -v wofi >/dev/null 2>&1; then
    printf 'wofi\n'
    return
  fi

  printf 'none\n'
}

terminal_bin() {
  if command -v "$TERMINAL_APP" >/dev/null 2>&1; then
    printf '%s\n' "$TERMINAL_APP"
    return
  fi

  if command -v kitty >/dev/null 2>&1; then
    printf 'kitty\n'
    return
  fi

  printf 'none\n'
}

open_terminal_command() {
  local command_text="$1"
  local term
  term="$(terminal_bin)"

  if [ "$term" = "none" ]; then
    notify "Nenhum terminal encontrado para concluir a autenticacao"
    exit 1
  fi

  "$term" sh -lc "$command_text; exit_code=\$?; printf '\n'; if [ \$exit_code -eq 0 ]; then echo 'Concluido.'; else echo 'Falhou com codigo ' \$exit_code; fi; printf 'Pressione Enter para fechar...'; read -r _" >/dev/null 2>&1 &
}

# ---------------------------------------------------------------------------
# NetworkManager: qualquer perfil vpn/wireguard entra no menu dinamicamente.
# O nome do perfil da FAI fica de fora (a FAI conecta via netExtender).
# ---------------------------------------------------------------------------

nm_profile_exists() {
  local profile="$1"
  command -v nmcli >/dev/null 2>&1 && nmcli -t -f NAME connection show 2>/dev/null | grep -Fxq "$profile"
}

nm_profile_active() {
  local profile="$1"
  command -v nmcli >/dev/null 2>&1 && nmcli -t -f TYPE,NAME connection show --active 2>/dev/null | awk -F: '$1=="vpn" || $1=="wireguard" {print $2}' | grep -Fxq "$profile"
}

nm_vpn_profiles() {
  command -v nmcli >/dev/null 2>&1 || return 0
  nmcli -t -f NAME,TYPE connection show 2>/dev/null \
    | awk -F: '$2=="vpn" || $2=="wireguard" {print $1}' \
    | grep -Fxv "$FAI_PROFILE" || true
}

nm_active_vpns() {
  command -v nmcli >/dev/null 2>&1 || return 0
  nmcli -t -f TYPE,NAME connection show --active 2>/dev/null \
    | awk -F: '$1=="vpn" || $1=="wireguard" {print $2}' \
    | grep -Fxv "$FAI_PROFILE" || true
}

connect_nm() {
  local profile="$1"

  if ! nm_profile_exists "$profile"; then
    notify "Perfil $profile nao encontrado no NetworkManager"
    exit 1
  fi

  # nmcli pode pedir segredos; o terminal interativo cobre todos os casos
  open_terminal_command "nmcli connection up id '$profile'"
}

disconnect_nm() {
  local profile="$1"

  if nm_profile_active "$profile"; then
    if nmcli connection down id "$profile" >/dev/null 2>&1; then
      notify "Desconectada: $profile"
      refresh_waybar
    else
      notify "Falha ao desconectar: $profile"
      exit 1
    fi
  fi
}

# ---------------------------------------------------------------------------
# FAI.UFSCAR: SonicWall, conecta pelo netExtender (nxcli) + daemon NEService.
# ---------------------------------------------------------------------------

# O netExtender exige um TTY ("Failed to set terminal to raw mode" sem ele),
# entao toda chamada passa por um pseudo-TTY alocado pelo script(1).
netextender_run() {
  script -qec "$1" /dev/null
}

netextender_status_output() {
  if ! command -v netExtender >/dev/null 2>&1; then
    return 0
  fi

  netextender_run "netExtender status" 2>/dev/null || true
}

fai_active() {
  # "Connected!!!" = clientes antigos; "has been connected" = nxcli 10.3+
  netextender_status_output | grep -qE "Connected!!!|has been connected"
}

neservice_running() {
  systemctl is-active --quiet NEService 2>/dev/null
}

# Senha da FAI vem do .env central do dotfiles (gitignored), chave FAI_VPN_PASSWORD.
fai_password() {
  local env_file="$DOTFILES_ROOT/.env"
  [ -r "$env_file" ] || return 1

  local pass
  pass="$(sed -n 's/^FAI_VPN_PASSWORD=//p' "$env_file" | tail -n 1)"
  pass="${pass%\'}" pass="${pass#\'}" pass="${pass%\"}" pass="${pass#\"}"

  [ -n "$pass" ] || return 1
  printf '%s\n' "$pass"
}

# Conexao sem terminal: roda o netExtender em background (com pseudo-TTY) e
# espera o status virar Connected. A senha vai por env var para nao aparecer
# no ps. Retorna 1 se nao conectar em 35s.
connect_fai_auto() {
  local pass="$1"
  local log="${XDG_RUNTIME_DIR:-/tmp}/netextender-fai.log"
  local pid i

  FAI_VPN_PASS="$pass" NX_PROFILE="$FAI_PROFILE" \
    setsid script -qec 'netExtender connect "$NX_PROFILE" -p "$FAI_VPN_PASS"' /dev/null \
    >"$log" 2>&1 &
  pid=$!

  for i in $(seq 1 35); do
    if fai_active; then
      return 0
    fi
    kill -0 "$pid" 2>/dev/null || break
    sleep 1
  done

  fai_active && return 0
  kill "$pid" 2>/dev/null
  return 1
}

connect_fai() {
  local script_path="$DOTFILES_ROOT/scripts/fai-ufscar-vpn.sh"

  if ! command -v netExtender >/dev/null 2>&1; then
    notify "netExtender nao encontrado. Instale com: yay -S netextender"
    exit 1
  fi

  if ! neservice_running; then
    if ! sudo -n systemctl start NEService >/dev/null 2>&1; then
      notify "NEService parado; abrindo terminal para iniciar com sudo"
      open_terminal_command "'$script_path'"
      return
    fi
  fi

  local pass
  if pass="$(fai_password)"; then
    notify "Conectando: $FAI_PROFILE..."
    if connect_fai_auto "$pass"; then
      notify "Conectada: $FAI_PROFILE"
      refresh_waybar
      return
    fi
    notify "Conexao automatica falhou; abrindo terminal interativo"
  fi

  if [ ! -x "$script_path" ]; then
    notify "Script da FAI nao encontrado ou sem permissao: $script_path"
    exit 1
  fi

  open_terminal_command "'$script_path'"
}

disconnect_fai() {
  if ! command -v netExtender >/dev/null 2>&1; then
    notify "netExtender nao encontrado"
    exit 1
  fi

  if netextender_run "netExtender disconnect" >/dev/null 2>&1 && ! fai_active; then
    notify "Desconectada: $FAI_PROFILE"
    refresh_waybar
    return
  fi

  if sudo -n true 2>/dev/null && netextender_run "sudo netExtender disconnect" >/dev/null 2>&1 && ! fai_active; then
    notify "Desconectada: $FAI_PROFILE"
    refresh_waybar
    return
  fi

  open_terminal_command "sudo netExtender disconnect"
}

# ---------------------------------------------------------------------------
# Operacoes por alvo: "fai", "ufscar" (atalho) ou o nome de qualquer perfil
# VPN do NetworkManager.
# ---------------------------------------------------------------------------

connect_target() {
  local target="$1"

  case "$target" in
    fai | "$FAI_PROFILE")
      connect_fai
      ;;
    ufscar)
      connect_nm "$UFSCAR_PROFILE"
      ;;
    *)
      connect_nm "$target"
      ;;
  esac
}

disconnect_target() {
  local target="$1"

  case "$target" in
    fai | "$FAI_PROFILE")
      disconnect_fai
      ;;
    ufscar)
      disconnect_nm "$UFSCAR_PROFILE"
      ;;
    all | "")
      disconnect_all
      ;;
    *)
      disconnect_nm "$target"
      ;;
  esac
}

list_active_labels() {
  nm_active_vpns

  if fai_active; then
    printf '%s\n' "$FAI_PROFILE"
  fi
}

disconnect_all() {
  local any_disconnected=0 profile

  while IFS= read -r profile; do
    [ -n "$profile" ] || continue
    disconnect_nm "$profile"
    any_disconnected=1
  done <<EOF
$(nm_active_vpns)
EOF

  if fai_active; then
    disconnect_fai
    any_disconnected=1
  fi

  if [ "$any_disconnected" -eq 0 ]; then
    notify "Nenhuma VPN ativa"
  fi
}

toggle_vpn() {
  local target="${1:-fai}"

  if [ -n "$(list_active_labels)" ]; then
    disconnect_all
    exit 0
  fi

  connect_target "$target"
}

show_menu() {
  local launcher options choice profile
  launcher="$(choose_launcher)"

  if [ "$launcher" = "none" ]; then
    notify "Instale rofi ou wofi para usar o menu de VPN"
    exit 1
  fi

  options=""

  if command -v netExtender >/dev/null 2>&1; then
    if fai_active; then
      options="${options}Desconectar: ${FAI_PROFILE}\n"
    else
      options="${options}Conectar: ${FAI_PROFILE}\n"
    fi
  fi

  while IFS= read -r profile; do
    [ -n "$profile" ] || continue
    if nm_profile_active "$profile"; then
      options="${options}Desconectar: ${profile}\n"
    else
      options="${options}Conectar: ${profile}\n"
    fi
  done <<EOF
$(nm_vpn_profiles)
EOF

  if [ -z "$options" ]; then
    notify "Nenhuma VPN configurada foi encontrada"
    exit 1
  fi

  if printf '%b' "$options" | grep -q '^Desconectar:'; then
    options="Desconectar todas\n${options}"
  fi

  if [ "$launcher" = "rofi" ]; then
    choice="$(printf '%b' "$options" | rofi -dmenu -i -p "VPN")"
  else
    choice="$(printf '%b' "$options" | wofi --dmenu --prompt "VPN")"
  fi

  [ -z "$choice" ] && exit 0

  case "$choice" in
    "Desconectar todas")
      disconnect_all
      ;;
    "Conectar: "*)
      connect_target "${choice#Conectar: }"
      ;;
    "Desconectar: "*)
      disconnect_target "${choice#Desconectar: }"
      ;;
  esac
}

show_status() {
  list_active_labels | paste -sd ',' -
}

# Saida estavel para o painel de VPN do quickshell: lista todas as VPNs
# (FAI via netExtender + perfis do NetworkManager) com o estado de cada uma.
show_status_json() {
  local items="" profile state neservice=false

  neservice_running && neservice=true

  if command -v netExtender >/dev/null 2>&1; then
    state=false
    fai_active && state=true
    items="{\"id\":\"fai\",\"name\":\"$(json_escape "$FAI_PROFILE")\",\"kind\":\"netextender\",\"connected\":${state}}"
  fi

  while IFS= read -r profile; do
    [ -n "$profile" ] || continue
    state=false
    nm_profile_active "$profile" && state=true
    [ -n "$items" ] && items="${items},"
    items="${items}{\"id\":\"$(json_escape "$profile")\",\"name\":\"$(json_escape "$profile")\",\"kind\":\"nm\",\"connected\":${state}}"
  done <<EOF
$(nm_vpn_profiles)
EOF

  printf '{"neservice":%s,"vpns":[%s]}\n' "$neservice" "$items"
}

mode="${1:-menu}"
case "$mode" in
  menu)
    show_menu
    ;;
  connect)
    if [ -z "${2:-}" ]; then
      printf 'Uso: %s connect [fai|ufscar|<perfil-nm>]\n' "$0"
      exit 1
    fi
    connect_target "$2"
    ;;
  disconnect)
    disconnect_target "${2:-all}"
    ;;
  toggle)
    toggle_vpn "${2:-fai}"
    ;;
  status)
    show_status
    ;;
  status-json)
    show_status_json
    ;;
  *)
    printf 'Uso: %s [menu|connect|disconnect|toggle|status|status-json]\n' "$0"
    exit 1
    ;;
esac
