# VS Code - cache e arquivos específicos da máquina
vscode/.config/Code/User/globalStorage/
vscode/.config/Code/User/workspaceStorage/
vscode/.config/Code/User/History/
vscode/.config/Code/User/sync/
vscode/.config/Code/User/profiles/
vscode/.config/Code/User/mcp/
vscode/.config/Code/User/*.log

# Ignore files containing apikey or api-key in the name
*apikey*
*api-key*

# Wallpapers - ignorar tudo em Pictures/ exceto Wallpapers/
wallpapers/Pictures/*
!wallpapers/Pictures/Wallpapers/

# NetworkManager - senhas de VPN (declarativo mas não versionado)
# networkmanager/.config/NetworkManager/system-connections/*.nmconnection

.env
tmp/

# --- Serviços versionados: configs ficam; estado/runtime/dados, não ---
# (o '.env' acima já cobre qualquer .env em qualquer subpasta)
cloudflare-ddns/logs/
cloudflare-ddns/.current_ip
homelab/jellyfin/config/
homelab/homepage/config/logs/
homelab/filebrowser/database/
homelab/rustdesk/data/

# Configs stowados: token e ruído de estado de janela ficam fora do git
gh/.config/gh/hosts.yml
vlc/.config/vlc/vlc-qt-interface.conf