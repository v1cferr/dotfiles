#%PAM-1.0
# ============================================================================
#  PAM do greetd (serviço que autentica o usuário real no login do greeter).
# ----------------------------------------------------------------------------
#  Acrescido de pam_gnome_keyring para DESTRAVAR a keyring "login"
#  automaticamente no login, usando a mesma senha digitada no greeter:
#    - auth    optional pam_gnome_keyring.so             -> captura a senha
#    - session optional pam_gnome_keyring.so auto_start  -> destrava + exporta
#                                                            SSH_AUTH_SOCK etc.
#  Sem isso (caso padrão do greetd) a keyring fica trancada e VS Code,
#  Claude Code CLI etc. pedem a senha a cada sessão.
#
#  REQUISITO: a keyring "login" precisa ter a MESMA senha do login e ser a
#  keyring padrão. Veja scripts/greetd/README e o deploy.
# ============================================================================

auth       required     pam_securetty.so
auth       requisite    pam_nologin.so
auth       include      system-local-login
auth       optional     pam_gnome_keyring.so
account    include      system-local-login
password   include      system-local-login
password   optional     pam_gnome_keyring.so
session    include      system-local-login
session    optional     pam_gnome_keyring.so auto_start
