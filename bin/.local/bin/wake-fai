#!/usr/bin/env bash
# ============================================================================
#  wake-fai — de casa: conecta a VPN da FAI, acorda a workstation (se estiver
#  desligada) e abre o SSH nela. Encadeia os passos que antes eram manuais.
# ----------------------------------------------------------------------------
#  Pré-req: 'vpn connect fai' funcionando (NEService ativo + FAI_VPN_PASSWORD
#  no ~/dotfiles/.env) e o send-wol.sh do toolkit. SEM dead-man de propósito:
#  é pra uso em casa, na frente do PC (pro caso remoto, fai-ufscar-vpn-remote.sh).
# ============================================================================
set -u

WS_USER="${WS_USER:-v1cferr}"
WS_IP="${WS_IP:-200.136.209.229}"     # superintendencia-server
WS_PORT="${WS_PORT:-22}"
BOOT_WAIT="${BOOT_WAIT:-150}"         # seg máx esperando a máquina subir (cold boot)
WOL="${WOL:-$HOME/dotfiles/netextender/wake-on-lan/send-wol.sh}"
KEEP_VPN=0

usage() {
  cat <<'EOF'
wake-fai — conecta a VPN da FAI, acorda a workstation (se preciso) e abre o SSH.
  wake-fai      VPN -> (WoL se preciso) -> ssh na workstation
  wake-fai -k   ao sair do SSH, MANTÉM a VPN conectada (não pergunta)
  wake-fai -h   esta ajuda
EOF
}

while getopts "kh" opt; do case "$opt" in
  k) KEEP_VPN=1 ;;
  h) usage; exit 0 ;;
  *) usage >&2; exit 1 ;;
esac; done

vpn_up() { vpn status 2>/dev/null | grep -qi "FAI"; }
ws_up()  { timeout 3 bash -c "exec 3<>/dev/tcp/${WS_IP}/${WS_PORT}" 2>/dev/null; }

# 1) VPN da FAI -------------------------------------------------------------
connected_now=0
# Trava: subir a VPN full-tunnel dentro de uma sessão SSH pode derrubar a
# própria sessão (sem route-pin). Em casa, no console, $SSH_CONNECTION é vazio.
if [ -n "${SSH_CONNECTION:-}" ] && ! vpn_up; then
  echo "⚠️  Você está numa sessão SSH. wake-fai sobe a VPN da FAI full-tunnel SEM"
  echo "    route-pin — isso pode DERRUBAR esta sessão e te trancar fora."
  echo "    Remoto seguro: sudo bash ~/dotfiles/scripts/fai-ufscar-vpn-remote.sh"
  printf "    Continuar mesmo assim? [y/N] "
  read -r ans; case "$ans" in [Yy]*) ;; *) echo "abortado."; exit 1 ;; esac
fi
if vpn_up; then
  echo "✓ VPN da FAI já conectada."
else
  echo "→ conectando à VPN da FAI..."
  vpn connect fai >/dev/null 2>&1 || true
  for _ in $(seq 1 35); do vpn_up && break; sleep 1; done
  if vpn_up; then
    echo "✓ VPN conectada."; connected_now=1
  else
    echo "✗ VPN não conectou. Tente: vpn connect fai" >&2; exit 1
  fi
fi

# 2) workstation ligada? ----------------------------------------------------
if ws_up; then
  echo "✓ workstation de pé (porta ${WS_PORT} aberta)."
else
  echo "→ workstation offline; mandando Wake-on-LAN..."
  [ -x "$WOL" ] || { echo "✗ send-wol.sh não executável: $WOL" >&2; exit 1; }
  "$WOL" -n 3
  printf "→ esperando bootar (até %ss): " "$BOOT_WAIT"
  for _ in $(seq 1 $((BOOT_WAIT/3))); do
    ws_up && { echo " up!"; break; }
    printf "."; sleep 3
  done
  ws_up || { echo; echo "✗ não subiu em ${BOOT_WAIT}s. Pode ser BIOS/WoL — repita ou verifique." >&2; exit 1; }
fi

# 3) SSH --------------------------------------------------------------------
echo "→ ssh ${WS_USER}@${WS_IP}"
ssh "${WS_USER}@${WS_IP}"

# 4) ao sair, oferece desconectar a VPN (só se fomos nós que ligamos) --------
if [ "$KEEP_VPN" -eq 0 ] && [ "$connected_now" -eq 1 ]; then
  printf "Desconectar a VPN da FAI agora? [Y/n] "
  read -r ans
  case "${ans:-Y}" in
    [Nn]*) echo "VPN mantida conectada." ;;
    *)     vpn disconnect fai >/dev/null 2>&1; echo "VPN desconectada." ;;
  esac
fi
