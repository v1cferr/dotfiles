{
    # E-mail para avisos da Let's Encrypt
    email {$CADDY_EMAIL}
    # Fixa a CA em produção (evita cair em staging por estado antigo)
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# Emite o certificado via DNS challenge da Cloudflare. Como é um curinga
# (*.v1cferr.dev), é UM único certificado para todos os subdomínios — sem
# disparar 10 pedidos de ACME ao mesmo tempo.
(cloudflare_dns) {
    tls {
        dns cloudflare {$CLOUDFLARE_API_TOKEN}
        resolvers 1.1.1.1 1.0.0.1
        # A checagem LOCAL de propagação do certmagic falha neste host (mesmo
        # forçando resolvers públicos). Mas o registro REALMENTE propaga
        # (8.8.8.8, 1.1.1.1 e o autoritativo confirmam) — e é o mundo que a
        # Let's Encrypt consulta. Então: espera fixa de 30s e DESLIGA a checagem
        # local (-1), deixando a LE validar direto.
        propagation_delay 30s
        propagation_timeout -1
    }
}

*.v1cferr.dev {
    import cloudflare_dns

    # Access log (JSON) -> journald. Usado pelo fail2ban (jail caddy-auth) para
    # banir brute-force no basic_auth do dashboard.
    log {
        format json
    }

    # ---- IA / LLMs ----
    # Ollama NÃO tem autenticação nativa — restrito à LAN (o open-webui o usa
    # internamente). Acesso de fora da rede recebe 403.
    @ai host ai.v1cferr.dev
    handle @ai {
        @ai_externo not remote_ip 192.168.1.0/24 127.0.0.1/8 ::1
        respond @ai_externo "Forbidden" 403
        reverse_proxy 127.0.0.1:11434
    }

    @chat host chat.v1cferr.dev
    handle @chat {
        reverse_proxy 127.0.0.1:3000
    }

    # ---- Stack de mídia ----
    # Jellyfin (network_mode: host) está bindado na IP da LAN, não no loopback.
    @jellyfin host jellyfin.v1cferr.dev
    handle @jellyfin {
        reverse_proxy 192.168.1.10:8096
    }

    @jellyseerr host jellyseerr.v1cferr.dev
    handle @jellyseerr {
        reverse_proxy 127.0.0.1:5055
    }

    @prowlarr host prowlarr.v1cferr.dev
    handle @prowlarr {
        reverse_proxy 127.0.0.1:9696
    }

    @radarr host radarr.v1cferr.dev
    handle @radarr {
        reverse_proxy 127.0.0.1:7878
    }

    @sonarr host sonarr.v1cferr.dev
    handle @sonarr {
        reverse_proxy 127.0.0.1:8989
    }

    @bazarr host bazarr.v1cferr.dev
    handle @bazarr {
        reverse_proxy 127.0.0.1:6767
    }

    @torrent host torrent.v1cferr.dev
    handle @torrent {
        reverse_proxy 127.0.0.1:8080
    }

    # ---- Projetos ----
    @spendflow host spendflow.v1cferr.dev
    handle @spendflow {
        reverse_proxy 127.0.0.1:3001
    }

    # ufscar-housing-radar (V1C-68) — apartamentos perto da UFSCar (app em Docker).
    @ap host ap.v1cferr.dev
    handle @ap {
        reverse_proxy 127.0.0.1:3005
    }

    # duo-streak-daemon (V1C-71) — console web (Next.js, container duo-web em
    # 3010; /api/* segue via Next para a API em 8010). Expõe detalhes da
    # automação, então fica restrito à LAN (mesmo padrão do ai.v1cferr.dev).
    @duo host duo.v1cferr.dev
    handle @duo {
        # 10.10.10.0/24 = túnel WireGuard (router .1, notebook .2, celular .3)
        @duo_externo not remote_ip 192.168.1.0/24 10.10.10.0/24 127.0.0.1/8 ::1
        respond @duo_externo "Forbidden" 403

        reverse_proxy 127.0.0.1:3010 {
            # SSE (/api/events): stream sem buffer
            flush_interval -1
        }
    }

    # ---- Dashboard (Homepage) ----
    # Acessível de fora, mas como expõe o mapa da infra, exige login (basic_auth)
    # para quem vem de FORA da LAN. Na LAN abre direto, sem senha.
    # Hash em {$CADDY_DASH_HASH} (no .env, fora do repo). Usuário: v1cferr.
    @dash host dash.v1cferr.dev
    handle @dash {
        @dash_externo not remote_ip 192.168.1.0/24 127.0.0.1/8 ::1
        basic_auth @dash_externo {
            v1cferr {$CADDY_DASH_HASH}
        }
        reverse_proxy 127.0.0.1:3003
    }

    # ---- Gerenciador de arquivos (FileBrowser) ----
    # Tem login próprio; exposto na internet. Brute-force no login é barrado
    # pela jail caddy-filebrowser do fail2ban.
    @files host files.v1cferr.dev
    handle @files {
        reverse_proxy 127.0.0.1:3004
    }

    # Subdomínio não mapeado -> 404 (em vez de erro feio)
    handle {
        respond "Subdomínio não configurado" 404
    }
}

# Para expor a API do SpendFlow (porta 8000), copie um bloco @/handle acima
# usando "api.spendflow.v1cferr.dev" e a porta 8000.
# OBS: FlareSolverr (8191) é helper interno do Prowlarr — não deve ser exposto.
